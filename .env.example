PUBLIC_BASE_URL=http://localhost:3000

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SECRET_KEY=your_supabase_secret_key
# Optional fallback if you prefer the old naming
# SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Kakao OAuth
KAKAO_REST_API_KEY=your_kakao_rest_api_key
KAKAO_CLIENT_SECRET=
KAKAO_REDIRECT_URI=http://localhost:3000/api/auth/kakao/callback

# Bizgo
BIZGO_BASE_URL=https://api.bizgo.io
BIZGO_API_KEY=your_bizgo_api_key
BIZGO_SENDER_KEY=your_bizgo_sender_key

# Optional: override hard-coded fallback master id
MASTER_KAKAO_ID=1234567890
